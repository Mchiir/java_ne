# ==============================================================================
# UTILITY BILLING SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and fill in your actual production/local credentials.
# ==============================================================================

# ===== Database Configuration =====
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password_here

# ===== Security / JWT =====
# Generate a 64-character base64 string using: 
# python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(48)).decode())"
JWT_SECRET=your_64_character_base64_encoded_jwt_secret_here

# ===== Email Configuration (Gmail SMTP) =====
MAIL_USERNAME=your_gmail_address@gmail.com
# For Gmail, use a 16-character App Password, NOT your primary password
MAIL_PASSWORD=your_gmail_app_password_here
