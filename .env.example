# ─── Utility Billing Management System — Environment Variables ───────────────
# Copy this file to .env and fill in real values before starting the application.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/utility_billing_db
DB_USERNAME=ubms_user
DB_PASSWORD=change_me_db_password

# ── PostgreSQL (Docker Compose / pgAdmin) ─────────────────────────────────────
POSTGRES_DB=utility_billing_db
POSTGRES_USER=ubms_user
POSTGRES_PASSWORD=change_me_db_password
PGADMIN_DEFAULT_EMAIL=admin@ubms.local
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a strong, random secret (≥ 256 bits recommended for HS256).
JWT_SECRET=replace_with_a_long_random_base64_encoded_secret_key
# Token validity in milliseconds (default: 3600000 = 1 hour)
JWT_EXPIRATION=3600000

# ── SMTP (Gmail or any SMTP relay) ────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-app-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
